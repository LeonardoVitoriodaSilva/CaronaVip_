# ─── BANCO DE DADOS ───────────────────────────────────────────────
# Substitua com seus dados do PostgreSQL local
DATABASE_URL="postgresql://postgres:sua_senha@localhost:5432/carona_vip"

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET="troque_por_chave_secreta_longa_aqui_min_32_chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="outra_chave_diferente_para_refresh_token"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── SERVIDOR ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── GOOGLE MAPS (opcional na fase inicial) ───────────────────────
GOOGLE_MAPS_API_KEY=
